# Git LFS 配置 - 跟踪大文件
# 跟踪所有 .tar.gz 文件（发布包）
*.tar.gz filter=lfs diff=lfs merge=lfs -text
# 跟踪大文件类型
*.pak filter=lfs diff=lfs merge=lfs -text
*.ucas filter=lfs diff=lfs merge=lfs -text
*.utoc filter=lfs diff=lfs merge=lfs -text
# 二进制文件
*.so filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
* !text !filter !merge !diff
dynamicmaps/moonworld.bin filter=lfs diff=lfs merge=lfs -text
open_sim_launcher filter=lfs diff=lfs merge=lfs -text
demo_gif/Scene/scene3.gif filter=lfs diff=lfs merge=lfs -text
